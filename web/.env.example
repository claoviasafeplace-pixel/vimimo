# === BASE DE DONNÉES ===
SUPABASE_URL=https://xxx.supabase.co
SUPABASE_SERVICE_ROLE_KEY=
NEXT_PUBLIC_SUPABASE_URL=https://xxx.supabase.co

# === AUTHENTIFICATION ===
NEXTAUTH_SECRET=                    # Random 64+ chars for JWT signing
AUTH_URL=https://your-domain.com    # NextAuth callback URL
AUTH_RESEND_KEY=                    # Resend API key for magic links
GOOGLE_CLIENT_ID=                  # Google OAuth (optional)
GOOGLE_CLIENT_SECRET=              # Google OAuth (optional)

# === PAIEMENTS ===
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# === SERVICES IA ===
REPLICATE_API_TOKEN=
REPLICATE_WEBHOOK_SECRET=          # Svix secret for webhook verification
OPENAI_API_KEY=

# === REMOTION ===
REMOTION_SERVER_URL=http://vps:3123
RENDER_SECRET=                     # Bearer token for render server auth

# === INNGEST ===
USE_INNGEST=true
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# === FEATURE FLAGS ===
USE_MOCK_AI=false                  # Set true for dev without API calls
COST_THRESHOLD_USD=10.0            # Max cost per project

# === URLS PUBLIQUES ===
NEXT_PUBLIC_APP_URL=https://your-domain.com
NEXT_PUBLIC_BASE_URL=https://your-domain.com
